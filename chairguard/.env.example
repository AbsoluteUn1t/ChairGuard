# ChairGuard Environment Variables
# Copy to .env and fill in values

# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=./data/chairguard.db

# AgentMail (email sending)
AGENTMAIL_API_KEY=am_us_inbox_6ccccca2c1e58525dc743ffae54fd7c9fb400fbbe31da502daabd4e297bc0661
AGENTMAIL_INBOX=growyourmargins@agentmail.to

# Twilio (SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Outscraper (lead discovery) - optional
OUTSCRAPER_API_KEY=your_outscraper_key_here

# Frontend URL (for CORS and links)
FRONTEND_URL=http://localhost:3000
